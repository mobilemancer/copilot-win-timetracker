<Window x:Class="TimeTracker.App.QuickEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="What are you doing now?"
        Width="420"
        Height="470"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptTitleTextBlock"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Text="What are you doing now?" />

        <TextBlock Grid.Row="1"
                   Margin="0,16,0,4"
                   Text="Customer" />
        <ComboBox x:Name="CustomerComboBox"
                  Grid.Row="2"
                  DisplayMemberPath="Name"
                  SelectionChanged="CustomerSelectionChanged" />

        <TextBlock Grid.Row="3"
                   Margin="0,16,0,4"
                   Text="Project" />
        <ComboBox x:Name="ProjectComboBox"
                  Grid.Row="4"
                  DisplayMemberPath="Name" />

        <Grid Grid.Row="5"
              Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Margin="0,0,0,4"
                           Text="Start" />
                <TextBox x:Name="StartTimeTextBox" />
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Margin="0,0,0,4"
                           Text="End" />
                <TextBox x:Name="EndTimeTextBox" />
            </StackPanel>
        </Grid>

        <Expander Grid.Row="6"
                  Margin="0,16,0,0"
                  Header="Additional details">
            <StackPanel Margin="0,12,0,0">
                <TextBlock Margin="0,0,0,4"
                           Text="Manual customer override" />
                <TextBox x:Name="ManualCustomerTextBox" />

                <TextBlock Margin="0,12,0,4"
                           Text="Manual project override" />
                <TextBox x:Name="ManualProjectTextBox" />

                <TextBlock Margin="0,12,0,4"
                           Text="Optional note" />
                <TextBox x:Name="NoteTextBox"
                         AcceptsReturn="True"
                         Height="90"
                         TextWrapping="Wrap" />
            </StackPanel>
        </Expander>

        <StackPanel Grid.Row="7"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Margin="0,0,8,0"
                    Padding="12,6"
                    Click="OpenOverviewClicked"
                    Content="Overview" />
            <Button Margin="0,0,8,0"
                    Padding="12,6"
                    Click="OpenSettingsClicked"
                    Content="Settings" />
            <Button Margin="0,0,8,0"
                    Padding="12,6"
                    Click="SkipClicked"
                    Content="Skip" />
            <Button Padding="16,6"
                    Click="SaveClicked"
                    Content="Save" />
        </StackPanel>
    </Grid>
</Window>
