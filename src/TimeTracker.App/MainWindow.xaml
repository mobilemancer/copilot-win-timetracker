<Window x:Class="TimeTracker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Copilot Time Tracker"
        Width="1000"
        Height="760"
        MinWidth="880"
        MinHeight="620">
    <Grid Margin="16">
        <TabControl x:Name="RootTabControl">
            <TabItem Header="Timeline / Overview">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center"
                                   Text="View" />
                        <ComboBox x:Name="OverviewModeComboBox"
                                  Width="100"
                                  Margin="8,0,16,0"
                                  SelectionChanged="OverviewModeChanged">
                            <ComboBoxItem Content="Day"
                                          IsSelected="True" />
                            <ComboBoxItem Content="Week" />
                        </ComboBox>

                        <DatePicker x:Name="OverviewDatePicker"
                                    SelectedDateChanged="OverviewDateChanged" />

                        <Button Margin="8,0,0,0"
                                Padding="12,4"
                                Click="TodayClicked"
                                Content="Today" />
                        <Button Margin="8,0,0,0"
                                Padding="12,4"
                                Click="RefreshClicked"
                                Content="Refresh" />
                        <Button Margin="8,0,0,0"
                                Padding="12,4"
                                Click="SaveEntriesClicked"
                                Content="Save changes" />
                    </StackPanel>

                    <GroupBox Grid.Row="1"
                              Margin="0,12,0,0"
                              Header="Visual timeline">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="TimelineItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="{Binding Width}"
                                                Margin="0,8,8,8"
                                                Padding="8"
                                                Background="#FFCCE5FF"
                                                BorderBrush="#FF7BA7D9"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding Title}" />
                                                <TextBlock FontSize="11"
                                                           Text="{Binding Subtitle}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </GroupBox>

                    <DataGrid x:Name="EntriesDataGrid"
                              Grid.Row="2"
                              Margin="0,12,0,0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding StartTimeText}"
                                                Header="Start"
                                                Width="150" />
                            <DataGridTextColumn Binding="{Binding EndTimeText}"
                                                Header="End"
                                                Width="150" />
                            <DataGridTextColumn Binding="{Binding CustomerName}"
                                                Header="Customer"
                                                Width="180" />
                            <DataGridTextColumn Binding="{Binding ProjectName}"
                                                Header="Project"
                                                Width="180" />
                            <DataGridTextColumn Binding="{Binding Note}"
                                                Header="Note"
                                                Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <WrapPanel>
                            <StackPanel Width="180">
                                <TextBlock Margin="0,0,0,4"
                                           Text="Working day start" />
                                <TextBox x:Name="WorkDayStartTextBox" />
                            </StackPanel>
                            <StackPanel Width="180"
                                        Margin="12,0,0,0">
                                <TextBlock Margin="0,0,0,4"
                                           Text="Working day end" />
                                <TextBox x:Name="WorkDayEndTextBox" />
                            </StackPanel>
                            <StackPanel Width="260"
                                        Margin="12,0,0,0">
                                <TextBlock Margin="0,0,0,4"
                                           Text="Summon hotkey" />
                                <TextBox x:Name="HotkeyTextBox" />
                            </StackPanel>
                        </WrapPanel>

                        <WrapPanel Margin="0,12,0,0">
                            <CheckBox x:Name="PausedCheckBox"
                                      Margin="0,0,16,0"
                                      Content="Pause reminders" />
                            <CheckBox x:Name="LaunchAtSignInCheckBox"
                                      Content="Launch at Windows sign-in" />
                        </WrapPanel>

                        <TextBlock Margin="0,20,0,8"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="Customers" />
                        <StackPanel Orientation="Horizontal">
                            <Button Padding="12,4"
                                    Click="AddCustomerClicked"
                                    Content="Add customer" />
                            <Button Margin="8,0,0,0"
                                    Padding="12,4"
                                    Click="RemoveCustomerClicked"
                                    Content="Remove selected" />
                        </StackPanel>
                        <DataGrid x:Name="CustomersDataGrid"
                                  Margin="0,8,0,0"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Name}"
                                                    Header="Name"
                                                    Width="*" />
                                <DataGridCheckBoxColumn Binding="{Binding IsInternal}"
                                                        Header="Internal"
                                                        Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Margin="0,20,0,8"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="Projects" />
                        <StackPanel Orientation="Horizontal">
                            <Button Padding="12,4"
                                    Click="AddProjectClicked"
                                    Content="Add project" />
                            <Button Margin="8,0,0,0"
                                    Padding="12,4"
                                    Click="RemoveProjectClicked"
                                    Content="Remove selected" />
                        </StackPanel>
                        <DataGrid x:Name="ProjectsDataGrid"
                                  Margin="0,8,0,0"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding CustomerName}"
                                                    Header="Customer"
                                                    Width="220" />
                                <DataGridTextColumn Binding="{Binding Name}"
                                                    Header="Project"
                                                    Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Margin="0,20,0,8"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="Office 365 accounts" />
                        <StackPanel Orientation="Horizontal">
                            <Button Padding="12,4"
                                    Click="AddAccountClicked"
                                    Content="Add account" />
                            <Button Margin="8,0,0,0"
                                    Padding="12,4"
                                    Click="RemoveAccountClicked"
                                    Content="Remove selected" />
                            <Button Margin="8,0,0,0"
                                    Padding="12,4"
                                    Click="SyncCalendarsClicked"
                                    Content="Sync calendars now" />
                        </StackPanel>
                        <DataGrid x:Name="AccountsDataGrid"
                                  Margin="0,8,0,0"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Binding="{Binding Enabled}"
                                                        Header="Enabled"
                                                        Width="90" />
                                <DataGridTextColumn Binding="{Binding DisplayName}"
                                                    Header="Email / label"
                                                    Width="250" />
                                <DataGridTextColumn Binding="{Binding TenantId}"
                                                    Header="Tenant ID"
                                                    Width="250" />
                                <DataGridTextColumn Binding="{Binding ClientId}"
                                                    Header="Client ID"
                                                    Width="250" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Button Margin="0,20,0,0"
                                Padding="16,6"
                                HorizontalAlignment="Right"
                                Click="SaveSettingsClicked"
                                Content="Save settings" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
